# ================================
# Example .env file for Dashboard API Gateway
# ================================

# Base URL of the Profile microservice
# This service handles user profiles (TENANT / OWNER / ADMIN)
PROFILE_API=http://localhost:3000

# Base URL of the Accommodation microservice
# Used to retrieve housing information and link accommodations to users
ACCOMMODATION_API=http://localhost:3003

# Base URL of the Lease microservice
# Manages lease creation, updates, and deletions
LEASE_API=http://localhost:5000

# Base URL of the Event microservice
# Handles calendar events, reminders, and notifications
# ⚠️ Note: /events is already included in the base URL
EVENT_API=http://localhost:6000/events

# Base URL of the Message microservice
# Enables sending and retrieving messages between users
# ⚠️ /api/messages is already included
MESSAGE_API=http://localhost:6001/api/messages

# URL of the Authentication and Authorization service
# Used to verify user permissions for protected actions
AUTH_SERVICE_URL=http://localhost:7000

# Optional: Set custom port for the API Gateway (default is 4000)
# PORT=4000
